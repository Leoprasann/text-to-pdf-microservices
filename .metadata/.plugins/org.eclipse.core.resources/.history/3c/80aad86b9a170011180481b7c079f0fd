spring.application.name=api-gateway
server.port=8080

eureka.client.service-url.defaultZone=http://localhost:8761/eureka

# Enable service discovery routing
# Route for Document Service
spring.cloud.gateway.routes[0].id=document-service
spring.cloud.gateway.routes[0].uri=lb://DOCUMENT-SERVICE
spring.cloud.gateway.routes[0].predicates[0]=Path=/documents/**